# 操作系统自动生成的文件
.DS_Store                # MacOS 隐藏文件
Thumbs.db                # Windows 缩略图缓存
desktop.ini              # Windows 配置文件
*.tmp                    # 临时文件
*.temp                   # 临时文件

# 编辑器/IDE 配置文件（覆盖主流编辑器）
.idea/                   # IntelliJ IDEA/WebStorm
.vscode/                 # VS Code
*.suo                    # Visual Studio
*.user                   # Visual Studio
*.userosscache           # Visual Studio
*.sln.docstates          # Visual Studio
.project                 # Eclipse
.classpath               # Eclipse
.c9/                     # Cloud9 IDE
*.launch                 # Eclipse
.settings/               # Eclipse
*.sublime-project        # Sublime Text
*.sublime-workspace      # Sublime Text
.tern-project            # Tern JS

# 浏览器缓存/调试文件
*.log                    # 日志文件
*.har                    # 网络请求日志
.cache/                  # 缓存目录

# 本地测试/备份文件（避免上传个人数据）
*.bak                    # 备份文件
*.backup                 # 备份文件
*-backup.html            # 本地修改的备份HTML
export_*.json            # 本地导出的任务JSON（避免上传个人数据）
import_*.json            # 本地导入的任务JSON

# 依赖/构建文件（本项目无构建流程，仅预留）
node_modules/            # npm 依赖（若后续扩展用到）
dist/                    # 构建输出目录
build/                   # 构建目录
coverage/                # 测试覆盖率报告
